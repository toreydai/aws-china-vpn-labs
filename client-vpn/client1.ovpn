client
dev tun
proto udp

# 替换为实际 VPN 服务器公网 IP
remote vpn.example.com 1194

resolv-retry infinite
nobind
persist-key
persist-tun

# 证书验证
ca ca.crt
remote-cert-tls server

# TLS 加固
tls-version-min 1.2
tls-crypt ta.key

# 加密：与服务端一致
data-ciphers AES-256-GCM:AES-128-GCM
data-ciphers-fallback AES-256-GCM

# 用户名/密码认证（禁用客户端证书时使用）
auth-user-pass

# 禁用压缩（VORACLE 漏洞缓解）
compress stub-v2

verb 3
